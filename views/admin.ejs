<!DOCTYPE html>
<html>
   <head>
      <title>Admin</title>
      <!-- <link rel="stylesheet" href="css/meme.css"> -->
      <link rel="stylesheet" href="css/style.css">
      <script src="./scripts/script.js" defer></script>
   </head>
   <body>
      <!--POST-->
      <main>
         <h1>Admin</h1>
         <h2>Post</h2>
         <div>
            <form action="/admin" method="post" class="inputForm">
               <input type="text" name="name" placeholder="Event Name"><br>
               <input type="text" name="date" placeholder="Event Date"><br>
               <textarea name="description" placeholder="Description"></textarea><br>
               <input type="submit" value="Submit">
            </form>
         </div>
         <br>
         <br>
         <!--GET-->
         <div class="search-wrapper">
            <label for="events-search-bar" style="display: block;">Search Events</label>
            <input type="search" id="events-search-bar">
            <div class="event-cards">
               <% events.forEach( (e) => { %>
               <div class="event-card">
                  <div class="header"><%= e.name %></div>
                  <div class="body">
                     <p class="description"><%= e.description %></p>
                     <p class="date"><%= (e.date == null) ? "DATE NOT EXIST" : e.date.toLocaleString() %></p>
                     <p class="mongoID" hidden="true"><%= e.id %></p>
                  </div>
               </div>
               <%})%>
            </div>
         </div>
      </main>
   </body>
</html>