<!DOCTYPE html>
<html>
    <head>
      <title>Event Admin Panel - ACM</title>
      <link rel="stylesheet" href="css/styles.css">
      <link rel="stylesheet" href="css/adminPanel.css">
      <script src="js/script.js"></script>
    </head>
    <body>
        <!--POST-->
        <!--GET-->
        <div>
            <form id="form" action="/admin" method="get" style="display: inline;"> 
                <input type="search" id="query" name="q" placeholder="Search...">
                <button>Submit</button>     
            </form> 
            <select name="actionEvent" id="actionEvent"> 
                <option value="editEvent">Edit</option> 
                <option value="deleteEvent">Delete</option> 
            </select>
        </div>
      <main>
        <div class="container">
          <h1 class="title">Admin Panel</h1>
          <h2 class="subtitle">Create New Event</h2>
          <div id="form_div">
            <form class="form" id="event_form" action="/admin" method="post">
              <label>Event Title</label>
              <input type="text" id="name" name="name" placeholder="Event Name">
              <label>Event Date</label>
              <input type="date" id="date" name="date" placeholder="Event Date">
              <label>Event Description</label>
              <textarea id="description" name="description" placeholder="Description"></textarea>
              <input class="btn" type="submit" value="Submit" onclick="submitEvent(event)">
            </form>
          </div>
        </div>
      </main>
    </body>
</html>